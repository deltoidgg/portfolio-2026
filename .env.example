# Neon serverless Postgres connection string (server only; never prefix with VITE_)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Runtime data selection for the archived Deadline Room.
MARKET_INTELLIGENCE_MODE=demo
MARKET_INTELLIGENCE_DEMO_FALLBACK=true

# Current season. The collector imports the official 380-fixture schedule before FPL launches.
MI_SEASON_KEY=epl:2026-27
MI_SEASON=2026/27
MI_SEASON_STARTS_AT=2026-08-21T00:00:00.000Z
MI_SEASON_ENDS_AT=2027-05-30T23:59:59.000Z
MI_RULESET_KEY=fpl:2026-27:provisional-v1
MI_FIXTURES_URL=https://www.premierleague.com/en/news/4675097/all-380-fixtures-for-202627-premier-league-season/

# Point-in-time capture and model jobs. Gameweek/deadline are optional manual overrides.
MI_GAMEWEEK=
MI_DEADLINE_AT=
MI_MODEL_INPUT=./data/inputs/market-intelligence/baseline-model.example.json
MI_MARKET_XP_INPUT=
MI_FORECAST_HORIZONS=1,3,5
MI_ODDS_MARKETS=h2h,totals
MI_RESULTS_STATUS=provisional
THE_ODDS_API_KEY=

# Cloudflare R2 raw snapshot archive (Actions only; never expose these to Vite/client code)
CLOUDFLARE_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=fpl-market-intelligence-raw
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
