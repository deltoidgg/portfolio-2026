# Neon serverless Postgres connection string (server only; never prefix with VITE_)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Runtime data selection. Omit for Neon when DATABASE_URL exists; use demo for the bundled replay.
MARKET_INTELLIGENCE_MODE=demo
MARKET_INTELLIGENCE_DEMO_FALLBACK=true

# Capture jobs
MI_SEASON=2025/26
MI_GAMEWEEK=34
MI_DEADLINE_AT=2026-04-24T17:30:00.000Z
MI_MODEL_INPUT=./data/inputs/market-intelligence/baseline-model.example.json
MI_ODDS_MARKETS=h2h,totals
THE_ODDS_API_KEY=
